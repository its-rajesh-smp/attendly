{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["./src/**/*", "./api/*.ts", "index.ts"],
  "exclude": ["node_modules"],
  "files": ["./src/types/global.d.ts"]
}
